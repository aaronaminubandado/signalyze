# Telegram API credentials (https://my.telegram.org)
API_ID=
API_HASH=

# Optional: enable LLM fallback parsing/classification.
# Leave blank to run in deterministic-only mode.
SIGNALYZE_LLM_PROVIDER=openai            # openai | none
SIGNALYZE_LLM_MODEL=gpt-4o-mini
OPENAI_API_KEY=

# Optional: market data provider for actual-performance evaluation.
# If unset, actual-performance phase will mark outcomes as INSUFFICIENT_DATA.
SIGNALYZE_MARKET_PROVIDER=twelvedata     # twelvedata | none
TWELVEDATA_API_KEY=

# Cost ceiling (USD) per pipeline run for runtime LLM calls.
SIGNALYZE_LLM_MAX_USD_PER_RUN=2.0
